{
  "name": "sisqueslabs/nestjs-template",
  "version": "0.1.5",
  "description": "Sisques Labs NestJS service template — DDD+CQRS+Hexagonal, TypeORM/Postgres, Kafka, GraphQL+REST, Sentry, Prometheus, MCP.",
  "author": "Sisques Labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/sisques-labs/nestjs-template.git"
  },
  "homepage": "https://github.com/sisques-labs/nestjs-template",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "debug": "nest start --debug --watch",
    "prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "gen:topics": "ts-node --transpile-only scripts/generate-aggregate-module-map.ts",
    "gen:topics:check": "ts-node --transpile-only scripts/generate-aggregate-module-map.ts --check",
    "test": "jest",
    "test:changed": "jest --onlyChanged",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:api": "pnpm test:e2e",
    "pretest:e2e": "node scripts/check-db.js",
    "test:integration": "jest --config ./test/jest-integration.json",
    "pretest:integration": "node scripts/check-db.js",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker compose -f docker-compose.test.yml down",
    "typeorm": "ts-node --project tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "pnpm typeorm migration:generate -d src/database/data-source.ts",
    "migration:create": "pnpm typeorm migration:create",
    "migration:run": "pnpm typeorm migration:run -d src/database/data-source.ts",
    "migration:revert": "pnpm typeorm migration:revert -d src/database/data-source.ts",
    "migration:show": "pnpm typeorm migration:show -d src/database/data-source.ts",
    "prepare": "node -e \"if(process.env.HUSKY!=='0')require('child_process').execSync('husky',{stdio:'inherit'})\""
  },
  "dependencies": {
    "@apollo/server": "^4.13.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/apollo": "^12.2.2",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/graphql": "^13.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/typeorm": "^11.0.1",
    "@sentry/nestjs": "^10.58.0",
    "@sentry/profiling-node": "^10.58.0",
    "@sisques-labs/nestjs-kit": "^1.3.1",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "graphql": "^16.14.0",
    "graphql-query-complexity": "^1.1.0",
    "graphql-type-json": "^0.3.2",
    "kafkajs": "^2.2.4",
    "nest-winston": "^1.10.2",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "typeorm": "^1.1.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.0.0",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.2.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^7.0.2",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.8",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@core/(.*)$": "<rootDir>/core/$1"
    }
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
