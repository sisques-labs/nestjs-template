PORT=3000
NODE_ENV=development

# Frontend base URL (used for CORS in dev; ignored when CORS_ORIGINS is set)
FRONTEND_URL=http://localhost:3001

# Allowed browser origins for credentialed CORS (comma-separated).
# Falls back to FRONTEND_URL when unset. Required in production.
# CORS_ORIGINS=http://localhost:3001,https://app.example.com

# PostgreSQL — individual connection vars (DATABASE_URL is NOT supported)
DATABASE_DRIVER=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=secret
DATABASE_DATABASE=nestjs_template_db
# Run pending migrations automatically on boot (default: true)
# DATABASE_MIGRATIONS_RUN=true
# Never set to true in production — dev/test convenience only
# DATABASE_SYNCHRONIZE=false

# Sentry (optional — SDK disabled when SENTRY_DSN is unset)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILE_SESSION_SAMPLE_RATE=1.0

# Kafka — domain event forwarding (opt-in; app boots without a broker when disabled)
KAFKA_ENABLED=false
# Comma-separated broker list — required when KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=nestjs-template
# Topics are ${KAFKA_TOPIC_PREFIX}.${module}, e.g. nestjs-template.plants
KAFKA_TOPIC_PREFIX=nestjs-template
KAFKA_SSL=false
# SASL is optional — set username + password to enable
KAFKA_SASL_MECHANISM=plain
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Logging
LOG_LEVEL=info
